<?xml version="1.0" encoding="utf-8"?>
<!--
  Long-form aspiration "Historian's Calling" — 4 tiers strung together.
  Showed to the player as a pick-on-creation aspiration; completing T4 grants the
  Habilitation Renown trait.

  Per EA's AspirationTrack TDESC and the Track_Motor golden:
    - module is `aspirations.aspiration_tuning` (not `aspirations.aspiration_track`)
    - i is `aspiration_track` (not `aspiration`)
    - the category field is named `category` (not `aspiration_category`)
    - the reward on track completion is a TunableReference named `reward`
      (we put the trait under `provided_traits` so it is granted while the track
      is active; the canonical reward chain lives in AspirationReward snippets).
-->
<I c="AspirationTrack" i="aspiration_track" m="aspirations.aspiration_tuning" n="aspiration_track_HistorianCalling" s="TBD_INSTANCE_ID">
  <T n="display_text">0xTBD_STBL_KEY_HC_ASPTRACK_NAME</T>
  <T n="description_text">0xTBD_STBL_KEY_HC_ASPTRACK_DESC</T>
  <T n="category">KNOWLEDGE</T>
  <L n="aspirations">
    <T>aspiration_HistorianCalling_T1</T>
    <T>aspiration_HistorianCalling_T2</T>
    <T>aspiration_HistorianCalling_T3</T>
    <T>aspiration_HistorianCalling_T4</T>
  </L>
  <!-- Reward trait granted while this track is the Sim's primary aspiration. -->
  <L n="provided_traits">
    <T>trait_HabilitationRenown</T>
  </L>
</I>
