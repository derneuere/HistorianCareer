<?xml version="1.0" encoding="utf-8"?>
<!--
  L4 — Juniorprofessor:in / Habilitand:in: "Habilitation Lecture".
  Heavy loot. Gated on Historian Level >= 3 AND Writing skill >= 7.
  Awards Medium statistic loot (the Habilitation is the big career step).
-->
<I c="SuperInteraction" i="interaction" m="interactions.base.super_interaction" n="HC_Interaction_HabilitationLecture" s="TBD_INSTANCE_ID">
  <T n="display_name">0xTBD_STBL_KEY_HC_INTERACTION_HABILITATION_LECTURE</T>
  <T n="pie_menu_category">HC_PieMenuCategory_Historian</T>
  <V n="basic_content" t="one_shot">
    <U n="one_shot">
      <L n="loot_list">
        <T>loot.basic_experience_pay_large</T>
        <T>HC_Loot_Add_HistorianLevel_Medium</T>
        <T>loot.buff_Confidence_High</T>
        <T>loot.buff_Focused_High</T>
      </L>
    </U>
  </V>
  <V n="test_globals" t="enabled">
    <U n="enabled">
      <L n="tests">
        <V t="statistic">
          <U n="statistic">
            <T n="subject">Actor</T>
            <T n="who">Actor</T>
            <T n="stat">HC_Statistic_HistorianLevel</T>
            <V n="value" t="threshold">
              <U n="threshold">
                <T n="comparison">GREATER_OR_EQUAL</T>
                <T n="value">3</T>
              </U>
            </V>
          </U>
        </V>
        <V t="skill_range">
          <U n="skill_range">
            <T n="subject">Actor</T>
            <T n="skill">statistic_skill_Adult_Writing</T>
            <V n="skill_range_type" t="threshold">
              <U n="threshold">
                <T n="comparison">GREATER_OR_EQUAL</T>
                <T n="value">7</T>
              </U>
            </V>
          </U>
        </V>
      </L>
    </U>
  </V>
</I>
