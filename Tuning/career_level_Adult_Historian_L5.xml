<?xml version="1.0" encoding="utf-8"?>
<!--
  L5: Professor:in (W3) — Lehrstuhl. Top pay, prestige hours.

  Field names per EA CareerLevel TDESC; see career_level_Adult_Historian_L1.xml.

  Skill gate (Research+Debate AND Writing both at 10, mimicking Habilitation) is
  not a CareerLevel field in EA tuning — see career_level_Adult_Historian_L3.xml.
  The Habilitation Renown trait is awarded via the aspiration track's
  `provided_traits`; per-level trait awards on promotion can be wired through
  `promotion_reward` (a TunableReference) once the reward snippet exists.
-->
<I c="CareerLevel" i="career_level" m="careers.career_tuning" n="career_level_Adult_Historian_L5" s="TBD_INSTANCE_ID">
  <T n="title">0xTBD_STBL_KEY_HC_LEVEL_5_TITLE</T>
  <T n="title_description">0xTBD_STBL_KEY_HC_LEVEL_5_DESC</T>
  <T n="simoleons_per_hour">340</T>

  <T n="performance_stat">HC_Statistic_HistorianLevel</T>

  <U n="performance_metrics">
    <T n="base_performance">8</T>
    <T n="missed_work_penalty">35</T>
    <L n="mood_metrics"/>
    <T n="performance_per_completed_goal">5</T>
    <L n="statistic_metrics"/>
    <L n="tested_metrics"/>
  </U>

  <!--
    Prestige Lehrstuhl hours: Tue-Fri 10:00-18:00 (duration=8h). Professors
    typically don't keep teaching hours on Monday in the German university
    calendar — research/admin day. Saturday and Sunday off.
  -->
  <U n="work_schedule">
    <L n="schedule_entries">
      <U>
        <U n="days_available">
          <T n="0 SUNDAY">False</T>
          <T n="1 MONDAY">False</T>
          <T n="2 TUESDAY">True</T>
          <T n="3 WEDNESDAY">True</T>
          <T n="4 THURSDAY">True</T>
          <T n="5 FRIDAY">True</T>
          <T n="6 SATURDAY">False</T>
        </U>
        <T n="duration">8</T>
        <U n="start_time">
          <T n="hour">10</T>
          <T n="minute">0</T>
        </U>
      </U>
    </L>
  </U>

  <U n="wakeup_time">
    <T n="hour">9</T>
    <T n="minute">0</T>
  </U>

  <T n="aspiration">aspiration_career_Historian_L5</T>
</I>
