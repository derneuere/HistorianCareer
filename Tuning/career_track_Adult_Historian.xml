<?xml version="1.0" encoding="utf-8"?>
<!--
  The single career track for the Historian career. Levels in order L1..L5.
  No branch_selection block is included because there is no branching.

  Note: per EA's CareerTrack tuning (see Build/simdata/test/golden/CareerTrack/
  GradeSchool_Track.tuning.xml), the class is "TunableCareerTrack" and the module
  is "careers.career_tuning". The career_name/career_description live on the
  Track, not the Career — EA's Career tuning only carries career_category and
  start_track at minimum.
-->
<I c="TunableCareerTrack" i="career_track" m="careers.career_tuning" n="career_track_Adult_Historian" s="TBD_INSTANCE_ID">
  <T n="career_name">0xTBD_STBL_KEY_HC_CAREER_NAME</T>
  <T n="career_description">0xTBD_STBL_KEY_HC_CAREER_DESCRIPTION</T>
  <L n="career_levels">
    <T>career_level_Adult_Historian_L1</T>
    <T>career_level_Adult_Historian_L2</T>
    <T>career_level_Adult_Historian_L3</T>
    <T>career_level_Adult_Historian_L4</T>
    <T>career_level_Adult_Historian_L5</T>
  </L>
</I>
