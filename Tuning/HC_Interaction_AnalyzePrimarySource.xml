<?xml version="1.0" encoding="utf-8"?>
<!-- L2 â€” Doktorand:in: "Analyze Primary Source". -->
<I c="SuperInteraction" i="interaction" m="interactions.base.super_interaction" n="HC_Interaction_AnalyzePrimarySource" s="TBD_INSTANCE_ID">
  <!--
    Pie-menu submenu grouping (issue #14). References our PieMenuCategory
    tuning by name; the build resolves it to a 31-bit decimal instance ID
    via SMALL_ID_CLASSES → smallInstanceIdFor(). Previously reverted in
    commit 6a663ba because the Olympus UI silently rejected the category
    (no SimData companion to register it). Now restored — the build emits
    a paired SimData for HC_PieMenuCategory_Historian via the
    PIE_MENU_CATEGORY_SCHEMA in Build/simdata. See
    Docs/NOTE_pie_menu_category_registration.md for the full rationale.
  -->
  <T n="category">HC_PieMenuCategory_Historian</T>
  <T n="display_name">0xTBD_STBL_KEY_HC_INTERACTION_ANALYZE_PRIMARY_SOURCE</T>
  <!--
    Gate to Historian career level >= 2 (PhD Candidate). See
    HC_Interaction_TranscribeManuscript.xml for the full rationale and the
    shape's provenance (issue #26).
  -->
  <L n="test_globals">
    <V t="career_test">
      <U n="career_test">
        <V n="test_type" t="career_track">
          <U n="career_track">
            <T n="career_track">career_track_Adult_Historian</T>
            <V n="user_level" t="enabled">
              <U n="enabled">
                <T n="lower_bound">2</T>
              </U>
            </V>
          </U>
        </V>
      </U>
    </V>
  </L>
  <!-- See HC_Interaction_TranscribeManuscript.xml for the rationale on
       interaction_category_tags (issue #14 hypothesis 2). -->
  <L n="interaction_category_tags">
    <T>Interaction_Super</T>
    <T>Interaction_All</T>
  </L>
  <V n="basic_content" t="one_shot"/>
  <V n="outcome" t="single">
    <U n="single">
      <U n="actions">
        <L n="loot_list">
          <T>HC_Loot_Add_HistorianLevel_Small</T>
        </L>
      </U>
    </U>
  </V>
</I>
