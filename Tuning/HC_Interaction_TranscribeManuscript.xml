<!--
  L1 â€” Wissenschaftliche Hilfskraft (HiWi): "Transcribe Manuscript".
  Minimal one-shot interaction. The only loot is our custom HC_Loot_Add_HistorianLevel_Small
  which ticks our internal statistic. EA's basic_experience_pay_* / buff_Confidence_High
  references were fabricated in the v0.1 scaffold and don't resolve.

  interaction_category_tags â€” TunableSet of Tag enum values. Present on
  1,124 of 1,124 EA SuperInteractions per issue #14's audit, so likely
  required infrastructure even when no per-category gating is wired. We
  declare the minimum-broad SI tags here. If/when the per-instance
  pie-menu `category` field is wired (blocked on issue #15's 32-bit ID
  resolver; see Docs/NOTE_pie_menu_category_ids.md), having
  interaction_category_tags already in place is hypothesis #2 from the
  issue: that EA's pie-menu generator needs broad tags declared before
  the per-instance `category` field works.
-->
<I c="SuperInteraction" i="interaction" m="interactions.base.super_interaction" n="HC_Interaction_TranscribeManuscript" s="TBD_INSTANCE_ID">
  <!--
    Pie-menu submenu grouping (issue #14). References our PieMenuCategory
    tuning by name; the build resolves it to a 31-bit decimal instance ID
    via SMALL_ID_CLASSES → smallInstanceIdFor() so EA's TunableReference
    resolver accepts it. If the in-game pie menu silently fails to open
    on right-click of a computer, this line is the first thing to remove
    (paired with interaction_category_tags above) — see
    Docs/NOTE_pie_menu_category_ids.md for the rollback rationale.
  -->
  <T n="category">HC_PieMenuCategory_Historian</T>
  <T n="display_name">0xTBD_STBL_KEY_HC_INTERACTION_TRANSCRIBE_MANUSCRIPT</T>
  <L n="interaction_category_tags">
    <T>Interaction_Super</T>
    <T>Interaction_All</T>
  </L>
  <V n="basic_content" t="one_shot"/>
  <V n="outcome" t="single">
    <U n="single">
      <U n="actions">
        <L n="loot_list">
          <T>HC_Loot_Add_HistorianLevel_Small</T>
        </L>
      </U>
    </U>
  </V>
</I>
