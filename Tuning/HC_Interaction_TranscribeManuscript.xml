<?xml version="1.0" encoding="utf-8"?>
<!--
  L1 — Wissenschaftliche Hilfskraft (HiWi): "Transcribe Manuscript".
  This is the ONLY interaction that enforces the University-History-degree prerequisite,
  because it is the entry point into the career. Subsequent levels gate on the statistic.

  test_globals carries a trait_test for the History major; trait reference is a placeholder
  to be confirmed in Sims 4 Studio at build time (Discover University EP).
-->
<I c="SuperInteraction" i="interaction" m="interactions.base.super_interaction" n="HC_Interaction_TranscribeManuscript" s="TBD_INSTANCE_ID">
  <T n="display_name">0xTBD_STBL_KEY_HC_INTERACTION_TRANSCRIBE_MANUSCRIPT</T>
  <T n="pie_menu_category">HC_PieMenuCategory_Historian</T>
  <V n="basic_content" t="one_shot">
    <U n="one_shot">
      <L n="loot_list">
        <T>loot.basic_experience_pay_small</T>
        <T>HC_Loot_Add_HistorianLevel_Small</T>
      </L>
    </U>
  </V>
  <V n="test_globals" t="enabled">
    <U n="enabled">
      <L n="tests">
        <!-- University: requires a completed History major.
             Replace the trait reference with the EP trait Sims 4 Studio resolves
             for "University Major: History (Completed)" at build time. -->
        <V t="trait">
          <U n="trait">
            <T n="subject">Actor</T>
            <L n="whitelist_traits">
              <T>trait_University_Major_History_Completed</T>
            </L>
          </U>
        </V>
      </L>
    </U>
  </V>
</I>
