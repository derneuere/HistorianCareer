<!--
  L1: Wissenschaftliche Hilfskraft (Research Assistant / HiWi). 20h/week, low pay.

  Per EA's CareerLevel TDESC and the SecretAgent_Villain_Level3 golden:
    - module is `careers.career_tuning` (not `careers.career_level`)
    - the level's display title is `title` (not `level_title`)
    - the level's tooltip blurb is `title_description` (not `level_description`)
    - the per-level Aspiration reference is `aspiration` (not `level_aspiration`)
-->
<I c="CareerLevel" i="career_level" m="careers.career_tuning" n="career_level_Adult_Historian_L1" s="TBD_INSTANCE_ID">
  <T n="title">0xTBD_STBL_KEY_HC_LEVEL_1_TITLE</T>
  <T n="title_description">0xTBD_STBL_KEY_HC_LEVEL_1_DESC</T>
  <T n="simoleons_per_hour">40</T>

  <!--
    Work schedule. EA references a CareerSchedule snippet — use `schedule_part_time_morning`
    (M/T/W/Th/F 09:00-13:00) as a stand-in until we author our own. If your install pins
    the snippet under a different namespace, swap in the one shown by S4S's Cruiser.
  -->
  <T n="schedule">schedule_career_part_time_morning</T>

  <!-- Daily task aspiration — what the player sees in the career UI. -->
  <T n="aspiration">aspiration_career_Historian_L1</T>
</I>
