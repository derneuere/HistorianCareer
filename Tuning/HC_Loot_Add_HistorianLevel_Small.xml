<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds +1 to the Historian level statistic on the acting Sim.
  Referenced by name from the L1/L2/L3 interactions.
-->
<I c="LootActions" i="action" m="interactions.utils.loot" n="HC_Loot_Add_HistorianLevel_Small" s="TBD_INSTANCE_ID">
  <L n="loot_actions">
    <V t="statistics">
      <U n="statistics">
        <L n="operations">
          <U>
            <T n="statistic">HC_PerformanceStat_Historian</T>
            <U n="advertise_and_modify">
              <T n="amount">1</T>
              <T n="subject">Actor</T>
            </U>
          </U>
        </L>
      </U>
    </V>
  </L>
</I>
