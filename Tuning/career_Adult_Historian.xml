<?xml version="1.0" encoding="utf-8"?>
<!--
  Historian career. Single track, 5 levels, modelled on the German academic Karriereleiter.

  Per EA's Career TDESC (Build/simdata/test/fixtures/tdescs/Career.tdesc.json) and
  the career_Teen_Retail golden, a Career resource carries career_category and
  start_track plus a handful of test/messaging/buff fields. The display name and
  description live on the CareerTrack, not the Career — see
  career_track_Adult_Historian.xml.

  Requires the History major from the Discover University EP. The trait reference
  `trait_University_Major_History_Completed` is a PLACEHOLDER — confirm the exact EA
  trait name in Sims 4 Studio's Game File Cruiser at build time (see IMPLEMENTATION_GUIDE.md
  and issue #2). The list of candidate names is also baked into the Python safety
  net in Scripts/historian_career/historian_career.py.
-->
<I c="Career" i="career" m="careers.career_tuning" n="career_Adult_Historian" s="TBD_INSTANCE_ID">
  <E n="career_category">CAREER</E>
  <T n="start_track">career_track_Adult_Historian</T>

  <!--
    Career availability test: only Sims who graduated with the History major can be hired.
    The canonical EA field is `career_availablity_tests` (note the EA spelling — no second
    'i' in "availability" — see Career.tdesc and the EA Teen Retail career golden).
  -->
  <L n="career_availablity_tests">
    <L>
      <V t="trait">
        <U n="trait">
          <L n="whitelist_traits">
            <T>trait_University_Major_History_Completed</T>
          </L>
        </U>
      </V>
    </L>
  </L>
</I>
