<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily-task helper that reuses an existing EA interaction:
  "Read a Book" — filtered to non-fiction. Falls back to the generic ReadBook affordance
  if the non-fiction subtype filter doesn't resolve.
-->
<I c="Objective" i="objective" m="aspirations.aspiration_objective" n="objective_HC_ReadNonfictionBook" s="TBD_INSTANCE_ID">
  <T n="display_text">0xTBD_STBL_KEY_HC_OBJ_READ_BOOK</T>
  <V n="goal_value" t="absolute">
    <T n="absolute">1</T>
  </V>
  <V n="objective_test" t="interaction_run_test">
    <U n="interaction_run_test">
      <L n="affordances">
        <!-- EA's non-fiction read; swap to `book_Read` if this specific affordance is missing. -->
        <T>book_ReadBook_NonFiction</T>
      </L>
      <T n="subject">Actor</T>
    </U>
  </V>
</I>
