<?xml version="1.0" encoding="utf-8"?>
<!--
  L3: Postdoktorand:in / Wiss. Mitarbeiter:in. 9-to-5, mid pay.
  Promotion to L3 requires Research & Debate skill ≥ 7 — enforced via promotion conditions.
-->
<I c="CareerLevel" i="career_level" m="careers.career_level" n="career_level_Adult_Historian_L3" s="TBD_INSTANCE_ID">
  <T n="level_title">0xTBD_STBL_KEY_HC_LEVEL_3_TITLE</T>
  <T n="level_description">0xTBD_STBL_KEY_HC_LEVEL_3_DESC</T>
  <T n="simoleons_per_hour">120</T>
  <T n="work_performance_progress_per_completion">7</T>
  <T n="schedule">schedule_career_standard_9_to_5</T>
  <T n="level_aspiration">aspiration_career_Historian_L3</T>
  <V n="outfit" t="default"/>

  <!-- Skill gate enforced on the promotion transition into this level. -->
  <V n="promotion_test" t="enabled">
    <U n="enabled">
      <L n="tests">
        <V t="skill_range">
          <U n="skill_range">
            <T n="subject">Actor</T>
            <T n="skill">statistic_skill_Adult_ResearchDebate</T>
            <V n="skill_range_type" t="threshold">
              <U n="threshold">
                <T n="comparison">GREATER_OR_EQUAL</T>
                <T n="value">7</T>
              </U>
            </V>
          </U>
        </V>
      </L>
    </U>
  </V>

  <L n="gameplay_unlocks"/>
</I>
