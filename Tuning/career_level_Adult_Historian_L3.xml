<?xml version="1.0" encoding="utf-8"?>
<!--
  L3: Postdoktorand:in / Wiss. Mitarbeiter:in. 9-to-5, mid pay.

  Field names per EA CareerLevel TDESC; see career_level_Adult_Historian_L1.xml.

  Skill gates (Research & Debate >= 7) are NOT a CareerLevel field in EA tuning;
  the canonical place is `block_promotion_tests` on the Career resource. Tracked
  for the v0.2 polish pass — for v0.1 the level is reachable without the gate.
-->
<I c="CareerLevel" i="career_level" m="careers.career_tuning" n="career_level_Adult_Historian_L3" s="TBD_INSTANCE_ID">
  <T n="title">0xTBD_STBL_KEY_HC_LEVEL_3_TITLE</T>
  <T n="title_description">0xTBD_STBL_KEY_HC_LEVEL_3_DESC</T>
  <T n="simoleons_per_hour">120</T>

  <!-- See L1 for rationale on ideal_mood; matches EA's Writer career convention. -->
  <T n="ideal_mood">14641</T>

  <T n="performance_stat">HC_PerformanceStat_Historian</T>

  <U n="performance_metrics">
    <T n="base_performance">8</T>
    <T n="missed_work_penalty">35</T>
    <L n="mood_metrics"/>
    <T n="performance_per_completed_goal">5</T>
    <L n="statistic_metrics"/>
    <L n="tested_metrics"/>
  </U>

  <!-- 9-to-5 Mon-Fri (duration=8h). -->
  <U n="work_schedule">
    <L n="schedule_entries">
      <U>
        <U n="days_available">
          <T n="0 SUNDAY">False</T>
          <T n="1 MONDAY">True</T>
          <T n="2 TUESDAY">True</T>
          <T n="3 WEDNESDAY">True</T>
          <T n="4 THURSDAY">True</T>
          <T n="5 FRIDAY">True</T>
          <T n="6 SATURDAY">False</T>
        </U>
        <T n="duration">8</T>
        <U n="start_time">
          <T n="hour">9</T>
          <T n="minute">0</T>
        </U>
      </U>
    </L>
  </U>

  <U n="wakeup_time">
    <T n="hour">8</T>
    <T n="minute">0</T>
  </U>

  <T n="aspiration">aspiration_career_Historian_L3</T>
</I>
