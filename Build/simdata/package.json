{
  "name": "simdata",
  "version": "0.1.0",
  "description": "Generate SimData (DATA) binaries from Sims 4 tuning XML — TypeScript port of the one Sims 4 Studio step that we couldn't script.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "simdata": "./dist/cli/simdata.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node --loader ts-node/esm src/cli/simdata.ts",
    "fetch-tdescs": "node scripts/fetch-tdescs.mjs",
    "fetch-tdescs:install-browser": "playwright install chromium"
  },
  "dependencies": {
    "@s4tk/hashing": "^0.2.1",
    "@s4tk/models": "^0.6.14",
    "@s4tk/xml-dom": "^0.2.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "playwright-core": "^1.39.0",
    "typescript": "^5.3.0",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=16"
  },
  "license": "MIT"
}
